# =============================================
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Maven wrapper downloads (keep mvnw scripts, ignore downloaded binaries)
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

