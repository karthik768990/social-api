# =============================================
nbproject/private/
nbbuild/
dist/
nbdist/
nb-configuration.xml

# =============================================
# OS Files
# =============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================
# Docker (keep docker-compose.yml, ignore overrides)
# =============================================
docker-compose.override.yml
docker-compose.local.yml

# =============================================
# Environment / Secrets -- NEVER commit these
# =============================================
.env
.env.*
!.env.example
application-local.properties
application-local.yml
application-secret.properties
*.pem
*.key
*.p12
*.jks
secrets/

# =============================================
# Test output
# =============================================
surefire-reports/
failsafe-reports/

# =============================================
# Keep these files
# =============================================
!.mvn/
!mvnw
!mvnw.cmd
!docker-compose.yml
!postman_collection.json
!README.md
